<UserControl x:Class="GHelper.WPF.Views.Panels.PerformancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls">

    <StackPanel>

        <!-- ========================================================== -->
        <!-- PERFORMANCE MODE — Silent / Balanced / Turbo arc selector   -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center">
                        <Run Text="Mode: " />
                        <Run Text="{Binding ModeSummaryLabel}" />
                    </TextBlock>
                    <controls:HelpButton HelpKey="perf_mode" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <controls:PerformanceModeArc
                    Height="180"
                    SelectedIndex="{Binding SelectedModeIndex, Mode=TwoWay}"
                    Items="{Binding ModeLabels}"
                    AccentColor="{DynamicResource AccentColor}" />
            </StackPanel>
        </Border>

        <!-- ========================================================== -->
        <!-- LIVE SENSORS — current CPU / GPU state                      -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Live Sensors"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                    <controls:HelpButton HelpKey="live_sensors" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <controls:SensorCard
                        Grid.Column="0"
                        Label="CPU"
                        IconGlyph="&#xE950;"
                        Temperature="{Binding CpuTemperature}"
                        FanSpeed="{Binding CpuFanSpeed}"
                        TargetSpeed="{Binding CpuTargetSpeed}" />

                    <controls:SensorCard
                        Grid.Column="2"
                        Label="GPU"
                        IconGlyph="&#xE7F4;"
                        Temperature="{Binding GpuTemperature}"
                        FanSpeed="{Binding GpuFanSpeed}"
                        TargetSpeed="{Binding GpuTargetSpeed}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================================== -->
        <!-- FAN & POWER CONTROL — strategy selector                     -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE9CA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Fan &amp; Power Control"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                    <controls:HelpButton HelpKey="fan_control" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <controls:PillSelector
                    Items="{Binding ApplyStrategyLabels}"
                    SelectedIndex="{Binding ApplyStrategyIndex, Mode=TwoWay}"
                    AccentColor="{DynamicResource AccentColor}"
                    Height="32" />
            </StackPanel>
        </Border>

        <!-- ========================================================== -->
        <!-- FAN BEHAVIOR — Fan Stop on Idle toggle                      -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE9CA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Fan Behavior"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Fan Stop on Idle" Style="{StaticResource BodyTextStyle}" />
                            <controls:HelpButton HelpKey="fan_stop_on_idle" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Silently coast fans to 0 RPM when CPU and GPU are both below 62°C. Resumes normal cooling when either crosses 72°C."
                                   Style="{StaticResource DimTextStyle}" FontSize="10"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding FanStopEnabled, Mode=TwoWay}"
                                           Width="44" Height="22"
                                           VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================================== -->
        <!-- FAN CURVES — only visible when Manual Fans / Both selected  -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}"
                Visibility="{Binding DataContext.ShowFanCurves, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"
                DataContext="{Binding FansPower}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9CA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Fan Curves"
                                   Style="{StaticResource CardTitleStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Content="Reset" HorizontalAlignment="Right"
                            Style="{StaticResource LinkButtonStyle}"
                            Command="{Binding ResetFanCurvesCommand}" />
                </Grid>

                <Border Style="{StaticResource CautionBannerStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource WarnOrangeBrush}"
                                   VerticalAlignment="Top" Margin="0,1,8,0" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource CautionBannerTextStyle}"
                                   Text="Changes apply live. Overly aggressive fan curves can cause throttling, excessive fan wear, or overheating." />
                    </Grid>
                </Border>

                <controls:FanCurveEditor x:Name="CpuCurveEditor"
                    Height="150"
                    Label="CPU Fan"
                    Temps="{Binding CpuFanTemps, Mode=TwoWay}"
                    Speeds="{Binding CpuFanSpeeds, Mode=TwoWay}"
                    BaseAccentColor="{DynamicResource AccentColor}"
                    AnimateColor="True"
                    HueOffset="0" />

                <controls:FanCurveEditor x:Name="GpuCurveEditor"
                    Height="150" Margin="0,8,0,0"
                    Label="GPU Fan"
                    Temps="{Binding GpuFanTemps, Mode=TwoWay}"
                    Speeds="{Binding GpuFanSpeeds, Mode=TwoWay}"
                    BaseAccentColor="{DynamicResource AccentColor}"
                    AnimateColor="True"
                    HueOffset="3.14" />
            </StackPanel>
        </Border>

        <!-- ========================================================== -->
        <!-- POWER LIMITS — only visible when Manual Power / Both        -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}"
                Visibility="{Binding DataContext.ShowPowerLimits, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"
                DataContext="{Binding FansPower}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xEA93;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Power Limits"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Border Style="{StaticResource CautionBannerStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource WarnOrangeBrush}"
                                   VerticalAlignment="Top" Margin="0,1,8,0" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource CautionBannerTextStyle}"
                                   Text="Changes apply live. Aggressive power limits can cause instability, shutdowns, or reduced component lifespan." />
                    </Grid>
                </Border>

                <!-- Total / SPL -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Total (SPL)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding TotalPowerLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding TotalPowerText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Slow Boost / sPPT -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Slow (sPPT)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding SlowBoostLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding SlowBoostText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Fast Boost / fPPT -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Fast (fPPT)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding FastBoostLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding FastBoostText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- CPU Limit -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding CpuPowerLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding CpuPowerText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
