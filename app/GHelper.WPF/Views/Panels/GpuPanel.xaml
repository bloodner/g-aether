<UserControl x:Class="GHelper.WPF.Views.Panels.GpuPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls"
             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <!-- Header.
                 Title lives on its own row so the restart chip below it can grow
                 freely without overlapping the mode name on narrow windows. The
                 chip row only takes vertical space when ShowRestart is true. -->
            <StackPanel Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE836;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding HeaderText}"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <controls:HelpButton HelpKey="gpu_mode" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,8,0,0"
                            Visibility="{Binding ShowRestart, Converter={StaticResource BoolToVisibility}}">

                    <!-- Idle: warning + "Restart now" action -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRestartPending, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="Requires Restart &#x26A0;"
                                   Foreground="{DynamicResource WarnOrangeBrush}"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <Button Content="Restart now"
                                Command="{Binding RestartNowCommand}"
                                Style="{StaticResource LinkButtonStyle}" />
                    </StackPanel>

                    <!-- Pending: countdown hint + Cancel -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRestartPending, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Restarting in ~30s&#x2026;"
                                   Foreground="{DynamicResource WarnOrangeBrush}"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Command="{Binding CancelRestartCommand}"
                                Style="{StaticResource LinkButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- GPU Schematic Diagram -->
            <controls:GpuSchematic
                Height="260"
                ActiveMode="{Binding SchematicMode}"
                ShowRestart="{Binding ShowRestart}"
                AccentColor="{DynamicResource AccentColor}"
                Margin="0,0,0,28" />

            <!-- Mode Selector Pills with Icons.
                 ItemColors passes the canonical mode palette so the selected pill fills
                 with its mode color — the same color that appears in the status bar and
                 tray icon, making the visual chain legible. -->
            <controls:PillSelector
                Height="34"
                Items="{Binding ModeLabels}"
                Icons="{Binding ModeIcons}"
                ItemColors="{Binding ModeColors}"
                AccentColor="{DynamicResource AccentColor}"
                SelectedIndex="{Binding SelectedModeIndex, Mode=TwoWay}" />
        </StackPanel>
    </Border>
</UserControl>
