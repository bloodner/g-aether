<UserControl x:Class="GHelper.WPF.Views.Panels.BatteryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#xE83F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="Charging &amp; Health"
                           Style="{StaticResource CardTitleStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Gauge + Info Row -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Circular Gauge -->
                <controls:CircularGauge
                    Width="110" Height="110"
                    Value="{Binding ChargePercentage}"
                    HealthText="{Binding HealthText}"
                    CyclesText="{Binding CyclesText}" />

                <!-- Info & Controls -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,4">
                        <Run Text="Status: " Foreground="{DynamicResource ForeDimBrush}" />
                        <Run Text="{Binding PowerStatusText}" />
                    </TextBlock>

                    <!-- Charge Limit -->
                    <TextBlock Style="{StaticResource DimTextStyle}" Text="Charge Limit" Margin="0,8,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Minimum="40" Maximum="100" Value="{Binding ChargeLimit, Mode=TwoWay}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding ChargeLimitText}"
                                   Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   MinWidth="32" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Battery Details -->
            <Border Margin="0,12,0,0" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Health" Style="{StaticResource DimTextStyle}" FontSize="10" />
                            <TextBlock Text="{Binding HealthText}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Cycles" Style="{StaticResource DimTextStyle}" FontSize="10" />
                            <TextBlock Text="{Binding CyclesText}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <!-- Battery Report -->
                    <Button Content="Generate Battery Report"
                            Command="{Binding BatteryReportCommand}"
                            Style="{StaticResource LinkButtonStyle}"
                            Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
