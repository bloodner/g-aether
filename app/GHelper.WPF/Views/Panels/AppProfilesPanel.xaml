<UserControl x:Class="GHelper.WPF.Views.Panels.AppProfilesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls">

    <StackPanel>

        <!-- ========================================================== -->
        <!-- APP PROFILES — process-focus rules that apply a scene       -->
        <!-- ========================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="App Profiles"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                    <controls:HelpButton HelpKey="app_profiles" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <TextBlock Text="When a matching app takes focus, the chosen scene applies automatically. Switching to an unprofiled app restores your prior settings."
                           Style="{StaticResource DimTextStyle}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,12" />

                <!-- Existing rules -->
                <ItemsControl ItemsSource="{Binding Rules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#13141B"
                                        BorderBrush="#22252E" BorderThickness="1"
                                        CornerRadius="6" Padding="12,7">
                                    <TextBlock Text="{Binding ProcessName}"
                                               Style="{StaticResource BodyTextStyle}"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="&#xE72A;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource ForeDimBrush}"
                                           VerticalAlignment="Center" Margin="10,0" />
                                <Border Grid.Column="2" Background="#13141B"
                                        BorderBrush="#22252E" BorderThickness="1"
                                        CornerRadius="6" Padding="12,7">
                                    <TextBlock Text="{Binding SceneName}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Button Grid.Column="3"
                                        Content="&#xE8BB;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Width="32" Height="32"
                                        Style="{StaticResource CloseButtonStyle}"
                                        Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Remove this rule" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock Text="No profiles yet — add one below to get started."
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource DimTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Rules.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Thin divider before the add row -->
                <Border Height="1" Background="#18FFFFFF" Margin="0,8,0,10" />

                <!-- Add rule row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding RunningProcesses}"
                              SelectedItem="{Binding NewRuleProcess, Mode=TwoWay}"
                              ToolTip="Pick a running app. Hit the refresh button if what you want isn't listed." />
                    <TextBlock Grid.Column="1" Text="&#xE72A;"
                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource ForeDimBrush}"
                               VerticalAlignment="Center" Margin="10,0" />
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding SceneNames}"
                              SelectedItem="{Binding NewRuleScene, Mode=TwoWay}" />
                    <Button Grid.Column="3"
                            Content="&#xE72C;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Width="32" Height="32"
                            Margin="8,0,0,0"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Command="{Binding RefreshRunningProcessesCommand}"
                            ToolTip="Rescan running apps" />
                    <Button Grid.Column="4"
                            Content="Add"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding AddRuleCommand}" />
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
