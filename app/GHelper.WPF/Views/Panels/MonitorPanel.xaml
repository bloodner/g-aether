<UserControl x:Class="GHelper.WPF.Views.Panels.MonitorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls">

    <Border Style="{StaticResource CardStyle}" Padding="14" VerticalAlignment="Stretch">
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <!-- Header row — standardizes the page with the rest of the app -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <!-- Row 2: CPU Temp + CPU Usage -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <!-- Row 4: dGPU Temp + dGPU Usage -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <!-- Row 6: dGPU Power (full width) -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <!-- Row 8: CPU Fan + GPU Fan -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <!-- Row 10: Battery -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Page header: Icon | Title | Tooltip.
                 Monitor is the one dashboard page — everything below is read-only data,
                 so we keep it as a single unified card (not multiple sections like the
                 other pages) but still give it the standard header treatment. -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="3"
                        Orientation="Horizontal">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="G-Scope"
                           Style="{StaticResource CardTitleStyle}"
                           VerticalAlignment="Center" />
                <controls:HelpButton HelpKey="monitor_telemetry" VerticalAlignment="Center" Margin="8,0,0,0" />
                <Button x:Name="ScopeSettingsButton"
                        Click="ScopeSettingsButton_Click"
                        VerticalAlignment="Center"
                        Margin="6,0,0,0"
                        Width="22" Height="22"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="G-Scope settings">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{DynamicResource ForeDimBrush}" />
                </Button>
            </StackPanel>

            <!-- Row 2: CPU Temp + CPU Usage. The CPU group is paired so users
                 see CPU heat and load side by side.
                 SparklineChart draws its own card background (fill, border,
                 halo, left stripe) so it drops straight into the grid — no outer
                 TileStyle wrapper. -->
            <controls:SparklineChart Grid.Row="2" Grid.Column="0"
                Height="{Binding SparklineHeight}"
                Label="CPU Temp"
                CurrentText="{Binding CpuTempText}"
                Values="{Binding CpuTempValues}"
                MaxValue="105"
                ValueFontSize="{Binding ValueFontSize}"
                StrokeColor="{Binding CpuTempStroke}"
                Visibility="{Binding ScopeShowCpuTemp, Converter={StaticResource BoolToVisibility}}" />
            <controls:SparklineChart Grid.Row="2" Grid.Column="2"
                Height="{Binding SparklineHeight}"
                Label="CPU Usage"
                CurrentText="{Binding CpuUseText}"
                Values="{Binding CpuUseValues}"
                MaxValue="100"
                ValueFontSize="{Binding ValueFontSize}"
                StrokeColor="{Binding CpuUseStroke}"
                Visibility="{Binding ScopeShowCpuUse, Converter={StaticResource BoolToVisibility}}" />

            <!-- Row 4: dGPU Temp + dGPU Usage (when active) OR dGPU Idle banner (when Eco) -->
            <controls:SparklineChart Grid.Row="4" Grid.Column="0"
                Height="{Binding SparklineHeight}"
                Label="dGPU Temp"
                CurrentText="{Binding GpuTempText}"
                Values="{Binding GpuTempValues}"
                MaxValue="95"
                ValueFontSize="{Binding ValueFontSize}"
                StrokeColor="{Binding GpuTempStroke}"
                Visibility="{Binding ShouldShowDgpuTemp, Converter={StaticResource BoolToVisibility}}" />
            <controls:SparklineChart Grid.Row="4" Grid.Column="2"
                Height="{Binding SparklineHeight}"
                Label="dGPU Usage"
                CurrentText="{Binding GpuUseText}"
                Values="{Binding GpuUseValues}"
                MaxValue="100"
                ValueFontSize="{Binding ValueFontSize}"
                StrokeColor="{Binding GpuUseStroke}"
                Visibility="{Binding ShouldShowDgpuUse, Converter={StaticResource BoolToVisibility}}" />
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                    Style="{StaticResource TileStyle}"
                    Visibility="{Binding IsGpuActive, Converter={StaticResource InverseBoolToVisibility}}"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource ForeDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="dGPU Off (Eco Mode)"
                               Style="{StaticResource DimTextStyle}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Row 6: dGPU Power (full width). Sits on its own line because the
                 sparkline has more breathing room and the "wattage" value reads
                 more naturally without a competing tile next to it. -->
            <controls:SparklineChart Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                Height="{Binding SparklineHeight}"
                Label="dGPU Power"
                CurrentText="{Binding GpuPowerText}"
                Values="{Binding GpuPowerValues}"
                MaxValue="150"
                ValueFontSize="{Binding ValueFontSize}"
                StrokeColor="{Binding GpuPowerStroke}"
                Visibility="{Binding ScopeShowPower, Converter={StaticResource BoolToVisibility}}" />

            <!-- Row 8: CPU Fan / GPU Fan -->
            <controls:SparklineChart Grid.Row="8" Grid.Column="0"
                Height="{Binding SparklineHeight}"
                Label="CPU Fan"
                CurrentText="{Binding CpuFanCurrentText}"
                Values="{Binding CpuFanValues}"
                MaxValue="7000"
                ValueFontSize="{Binding ValueFontSizeFan}"
                StrokeColor="{Binding CpuFanStroke}"
                Visibility="{Binding ScopeShowCpuFan, Converter={StaticResource BoolToVisibility}}" />
            <controls:SparklineChart Grid.Row="8" Grid.Column="2"
                Height="{Binding SparklineHeight}"
                Label="GPU Fan"
                CurrentText="{Binding GpuFanCurrentText}"
                Values="{Binding GpuFanValues}"
                MaxValue="7000"
                ValueFontSize="{Binding ValueFontSizeFan}"
                StrokeColor="{Binding GpuFanStroke}"
                Visibility="{Binding ScopeShowGpuFan, Converter={StaticResource BoolToVisibility}}" />

            <!-- Row 10: Battery Status (full width) — halo color tracks BatteryBrush
                 (green when charging/healthy, amber/orange/red as charge drops). -->
            <Grid Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3"
                  Visibility="{Binding ScopeShowBattery, Converter={StaticResource BoolToVisibility}}">
                <controls:AccentHaloBackground AccentColor="{Binding BatteryAccentColor}" />
                <Grid Margin="18,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="{Binding BatteryPercentText}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{Binding BatteryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PowerStatusText}"
                                   Style="{StaticResource DimTextStyle}"
                                   FontSize="10"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource DimTextStyle}" Text="Battery" Margin="0,0,0,2" />
                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                   Text="{Binding BatteryRateText}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
