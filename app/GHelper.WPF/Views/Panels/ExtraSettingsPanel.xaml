<UserControl x:Class="GHelper.WPF.Views.Panels.ExtraSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls"
             xmlns:panels="clr-namespace:GHelper.WPF.Views.Panels">

    <StackPanel>

        <!-- ======================================================== -->
        <!-- STARTUP & BEHAVIOR                                       -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Startup &amp; Behavior"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Run on Startup" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Text="Launch automatically when you log in"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding RunOnStartup, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Fn Lock" Style="{StaticResource BodyTextStyle}" />
                            <controls:HelpButton HelpKey="fn_lock" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Use F1-F12 as standard function keys"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding FnLockEnabled, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Boot Sound" Style="{StaticResource BodyTextStyle}" />
                            <controls:HelpButton HelpKey="boot_sound" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="ASUS POST sound on startup"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding BootSound, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="GPU Fix on Shutdown" Style="{StaticResource BodyTextStyle}" />
                            <controls:HelpButton HelpKey="gpu_fix" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Disable dGPU before shutdown"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding GpuFixEnabled, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================================================== -->
        <!-- APPEARANCE                                               -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Appearance"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Always on Top" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Text="Keep window above all other windows"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding WindowTopmost, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="B&amp;W Tray Icon" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Text="Use monochrome system tray icon"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding BwTrayIcon, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>

                <!-- Transparency slider -->
                <StackPanel Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Window Transparency" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Grid.Column="1"
                                   FontSize="10"
                                   Foreground="#8090909A"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding WindowOpacity, StringFormat={}{0:P0}, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Lower = more see-through"
                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                    <Slider Minimum="0.60" Maximum="1.00"
                            Value="{Binding WindowOpacity, Mode=TwoWay}"
                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                            Margin="0,4,0,0" />
                </StackPanel>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Advanced RGB" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Text="Enable per-key RGB control (requires restart)"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding AdvancedRgb, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================================================== -->
        <!-- FLOATING GADGET                                          -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Floating Gadget"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                    <controls:HelpButton HelpKey="floating_gadget" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <TextBlock Text="Compact live telemetry that stays on top of games and other apps."
                           Style="{StaticResource DimTextStyle}"
                           FontSize="11"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Show gadget" Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Text="Live telemetry, always on top, drag to reposition"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <controls:ToggleSwitch Grid.Column="1"
                                           IsChecked="{Binding ShowGadget, Mode=TwoWay}"
                                           Width="44" Height="22" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                    <Button Grid.Column="2"
                            Content="Configure..."
                            Command="{Binding OpenGadgetSettingsCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================================================== -->
        <!-- SMART OPTIMIZE                                           -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Smart Optimize"
                                   Style="{StaticResource CardTitleStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding OptimizeButtonText}"
                            Command="{Binding OptimizeForMeCommand}"
                            IsEnabled="{Binding OptimizeButtonEnabled}"
                            Style="{StaticResource SecondaryActionButtonStyle}" />
                </Grid>

                <TextBlock Text="Analyzes your usage patterns and sets optimal performance, GPU, and display settings."
                           Style="{StaticResource DimTextStyle}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,0,0,4" />

                <!-- Results -->
                <StackPanel Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OptimizeResultVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Background="#18FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,0,0,6"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding OptimizeProfileName}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding OptimizeReason}"
                               FontSize="10" Foreground="#80FFFFFF"
                               TextWrapping="Wrap" Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding OptimizeRecommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="8"
                                               VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE73E;" />
                                                <Setter Property="Foreground" Value="#4CC95E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChange}" Value="True">
                                                        <Setter Property="Text" Value="&#xE72C;" />
                                                        <Setter Property="Foreground" Value="#60CDFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding SettingName}"
                                                   FontSize="11" Foreground="#DDFFFFFF" />
                                        <TextBlock Text="{Binding Reason}"
                                                   FontSize="9" Foreground="#60FFFFFF" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" FontSize="10"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Text="{Binding RecommendedValue}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4CC95E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChange}" Value="True">
                                                        <Setter Property="Foreground" Value="#60CDFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Dismiss"
                                Command="{Binding DismissOptimizeCommand}"
                                Style="{StaticResource LinkButtonStyle}"
                                VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Content="{Binding OptimizeApplyButtonText}"
                                Command="{Binding ApplyOptimizeCommand}"
                                IsEnabled="{Binding OptimizeApplyEnabled}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryApplyButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OptimizeApplyVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ======================================================== -->
        <!-- APP PROFILES â€” embedded from AppProfilesPanel. DataContext  -->
        <!-- walks up to the root MainViewModel to reach .AppProfiles.   -->
        <!-- ======================================================== -->
        <panels:AppProfilesPanel DataContext="{Binding DataContext.AppProfiles, RelativeSource={RelativeSource AncestorType=Window}}" />

        <!-- ======================================================== -->
        <!-- ASUS SERVICES                                            -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="ASUS Services"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Summary row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                               VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE72E;" />
                                <Setter Property="Foreground" Value="#4CC95E" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AsusServicesCount}" Value="0">
                                        <Setter Property="Text" Value="&#xE73E;" />
                                        <Setter Property="Foreground" Value="#4CC95E" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status"
                                       Style="{StaticResource BodyTextStyle}" />
                            <controls:HelpButton HelpKey="asus_services" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding AsusServicesText}"
                                   Style="{StaticResource DimTextStyle}" FontSize="10" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Command="{Binding ToggleServicesExpandedCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand" VerticalAlignment="Center"
                            Margin="0,0,4,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="#80FFFFFF">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE70D;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServicesExpanded}" Value="True">
                                            <Setter Property="Text" Value="&#xE70E;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="3"
                            Content="{Binding AsusServicesButtonText}"
                            Command="{Binding ToggleAsusServicesCommand}"
                            IsEnabled="{Binding AsusServicesButtonEnabled}"
                            Style="{StaticResource SecondaryActionButtonStyle}" />
                </Grid>

                <!-- Expanded content: Armoury Crate toggle + per-service list -->
                <StackPanel Margin="0,10,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServicesExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Include Armoury Crate toggle -->
                    <Border Padding="4,6" Background="#08FFFFFF" CornerRadius="4" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Include Armoury Crate"
                                           FontSize="11" FontWeight="Medium" Foreground="#E0E0E5" />
                                <TextBlock Text="Also manage Armoury Crate, LightingService, and related core processes"
                                           FontSize="9" Foreground="#70707A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:ToggleSwitch Grid.Column="1"
                                                   IsChecked="{Binding StopArmoryCrate, Mode=TwoWay}"
                                                   Width="44" Height="22"
                                                   VerticalAlignment="Center" Margin="8,0,4,0" />
                        </Grid>
                    </Border>

                    <!-- Per-service list -->
                    <ItemsControl ItemsSource="{Binding ServiceDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,3" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                   VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xEA39;" />
                                                    <Setter Property="Foreground" Value="#50FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Text" Value="&#xEA3A;" />
                                                            <Setter Property="Foreground" Value="#FF6B35" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="11" Foreground="#DDFFFFFF" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9" Foreground="#60FFFFFF" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   FontSize="9" Margin="8,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Stopped" />
                                                    <Setter Property="Foreground" Value="#50FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Text" Value="Running" />
                                                            <Setter Property="Foreground" Value="#FF6B35" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ======================================================== -->
        <!-- ABOUT                                                    -->
        <!-- ======================================================== -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="About"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="{Binding UpdateButtonText}"
                            Command="{Binding CheckForUpdatesCommand}"
                            IsEnabled="{Binding UpdateButtonEnabled}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Margin="0,0,4,0"
                            HorizontalAlignment="Stretch" />
                    <Button Grid.Column="1"
                            Content="View Changelog"
                            Command="{Binding ShowChangelogCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Margin="4,0,0,0"
                            HorizontalAlignment="Stretch" />
                </Grid>
                <TextBlock Text="{Binding UpdateStatusText}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource DimTextStyle}">
                            <Setter Property="FontSize" Value="10" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                    <Setter Property="Foreground" Value="#FF6B35" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Style="{StaticResource DimTextStyle}"
                           FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Text="{Binding VersionText}" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
