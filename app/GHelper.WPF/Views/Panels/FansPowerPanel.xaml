<UserControl x:Class="GHelper.WPF.Views.Panels.FansPowerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GHelper.WPF.Controls">

    <StackPanel Margin="0,0,0,8">

        <!-- Fan Curves Section -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource CardTitleStyle}">
                        <Run Text="&#xE9CA;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        <Run Text="  Fan Curves" />
                    </TextBlock>
                    <Button Content="Reset" HorizontalAlignment="Right"
                            Style="{StaticResource LinkButtonStyle}"
                            Command="{Binding ResetFanCurvesCommand}" />
                </Grid>

                <!-- CPU Fan Curve -->
                <controls:FanCurveEditor x:Name="CpuCurveEditor"
                    Height="150"
                    Label="CPU Fan"
                    Temps="{Binding CpuFanTemps, Mode=TwoWay}"
                    Speeds="{Binding CpuFanSpeeds, Mode=TwoWay}"
                    BaseAccentColor="{DynamicResource AccentColor}"
                    AnimateColor="True"
                    HueOffset="0" />

                <!-- GPU Fan Curve -->
                <controls:FanCurveEditor x:Name="GpuCurveEditor"
                    Height="150" Margin="0,8,0,0"
                    Label="GPU Fan"
                    Temps="{Binding GpuFanTemps, Mode=TwoWay}"
                    Speeds="{Binding GpuFanSpeeds, Mode=TwoWay}"
                    BaseAccentColor="{DynamicResource AccentColor}"
                    AnimateColor="True"
                    HueOffset="3.14" />
            </StackPanel>
        </Border>

        <!-- Power Limits Section -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource CardTitleStyle}">
                        <Run Text="&#xEA93;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        <Run Text="  Power Limits" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="Auto-Apply" Style="{StaticResource DimTextStyle}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <controls:ToggleSwitch IsChecked="{Binding AutoApplyPower, Mode=TwoWay}"
                                               Width="40" Height="20" />
                    </StackPanel>
                </Grid>

                <!-- Total / SPL -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Total (SPL)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding TotalPowerLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding TotalPowerText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Slow Boost / sPPT -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Slow (sPPT)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding SlowBoostLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding SlowBoostText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Fast Boost / fPPT -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Fast (fPPT)" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding FastBoostLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding FastBoostText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- CPU Limit -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="{Binding MinPower}" Maximum="{Binding MaxPower}"
                            Value="{Binding CpuPowerLimit, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding CpuPowerText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- GPU Clocks Section (only for NVIDIA) -->
        <Border Style="{StaticResource CardStyle}"
                Visibility="{Binding HasNvidiaGpu, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource CardTitleStyle}">
                        <Run Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        <Run Text="{Binding GpuName, Mode=OneWay}" />
                    </TextBlock>
                    <Button Content="Reset" HorizontalAlignment="Right"
                            Style="{StaticResource LinkButtonStyle}"
                            Command="{Binding ResetGpuClocksCommand}" />
                </Grid>

                <!-- Core Offset -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Core Clock" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding MinCoreOffset}" Maximum="{Binding MaxCoreOffset}"
                            Value="{Binding GpuCoreOffset, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding GpuCoreText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Memory Offset -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Memory" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding MinMemoryOffset}" Maximum="{Binding MaxMemoryOffset}"
                            Value="{Binding GpuMemoryOffset, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding GpuMemoryText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Boost Power -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Boost Power" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="0" Maximum="200"
                            Value="{Binding GpuBoostPower, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding GpuBoostText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>

                <!-- Temp Target -->
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Temp Target" Style="{StaticResource DimTextStyle}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Minimum="75" Maximum="87"
                            Value="{Binding GpuTempTarget, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding GpuTempText}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
