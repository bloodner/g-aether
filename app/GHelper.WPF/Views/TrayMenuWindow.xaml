<Window x:Class="GHelper.WPF.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="MenuItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7,10,7"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border x:Name="MenuBorder"
                Background="#E6141420"
                CornerRadius="12"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Padding="6"
                RenderTransformOrigin="1,1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="4" Opacity="0.55"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="MenuScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <StackPanel x:Name="MenuStack" Width="236"/>
        </Border>
    </Grid>
</Window>
