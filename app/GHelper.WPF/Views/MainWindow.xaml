<Window x:Class="GHelper.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:panels="clr-namespace:GHelper.WPF.Views.Panels"
        Title="G-Aether"
        Icon="/Resources/icon.png"
        Width="500"
        Height="620"
        MinWidth="480" MinHeight="400"
        MaxHeight="900"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Foreground="{DynamicResource ForeMainBrush}"
        FontFamily="Segoe UI Variable">

    <!-- Semi-transparent dark background with rounded corners -->
    <Border Background="#D0141420" CornerRadius="12"
            BorderBrush="#18FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Minimal Title Bar (draggable, spans both columns) -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Width="58" TextAlignment="Center" />
                    <TextBlock Text="G-" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForeMainBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Aether" FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Content="&#xE921;"
                            Width="32" Height="28"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    <Button x:Name="CloseButton"
                            Content="&#xE8BB;"
                            Width="32" Height="28"
                            Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}" />
                </StackPanel>
            </Grid>

            <!-- Side Navigation Rail -->
            <Border Grid.Row="3" Grid.Column="0">
                <DockPanel Margin="0,4,0,8" HorizontalAlignment="Stretch">
                    <!-- Settings icon pinned to bottom, with service health dot -->
                    <Grid DockPanel.Dock="Bottom">
                        <RadioButton x:Name="NavExtra" Content="&#xE713;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Settings" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="8" />
                        <!-- Warning dot: visible when ASUS services are running -->
                        <Ellipse Width="7" Height="7"
                                 Fill="#FF6B35"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,6,10,0"
                                 IsHitTestVisible="False">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Extra.AsusServicesCount}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Border DockPanel.Dock="Bottom" Height="1" Margin="6,4,6,4"
                            Background="#18FFFFFF" />

                    <!-- Main nav items -->
                    <StackPanel>
                        <RadioButton x:Name="NavMonitor" Content="&#xE9D9;"
                                     Style="{StaticResource NavIconStyle}"
                                     IsChecked="True" ToolTip="Monitor" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="0" />
                        <RadioButton x:Name="NavPerformance" Content="&#xE945;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Performance" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="1" />
                        <RadioButton x:Name="NavGpu" Content="&#xE7F4;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="GPU Mode" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="3" />
                        <RadioButton x:Name="NavBattery" Content="&#xEA93;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Battery" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="4" />
                        <RadioButton x:Name="NavDisplay" Content="&#xE7F8;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Display" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="5" />
                        <RadioButton x:Name="NavLighting" Content="&#xE781;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Lighting" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="6" />
                        <RadioButton x:Name="NavKeyBindings" Content="&#xE92E;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Key Bindings" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="7" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Mode Badge Strip (spans both columns, full width) -->
            <Border Grid.Row="1" Grid.ColumnSpan="2"
                    Margin="14,0,14,10"
                    Padding="2"
                    Background="#06FFFFFF"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Perf badge -->
                        <Button Grid.Column="0" Style="{StaticResource ModeBadgeStyle}"
                                BorderBrush="{Binding PerfBadgeBrush}"
                                Tag="1" Click="ModeBadge_Click" ToolTip="Performance Mode">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="7" Height="7"
                                         Fill="{Binding PerfBadgeBrush}"
                                         VerticalAlignment="Center" Margin="0,0,7,0"
                                         IsEnabled="{Binding PerfBadgeIsWarning}"
                                         Style="{StaticResource WarningPulseDotStyle}" />
                                <TextBlock Text="&#xE945;" Style="{StaticResource ModeBadgeIconStyle}"
                                           Foreground="{Binding PerfBadgeBrush}" />
                                <TextBlock Text="{Binding PerfBadgeName}"
                                           Style="{StaticResource ModeBadgeValueStyle}"
                                           Foreground="{Binding PerfBadgeBrush}" />
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="1" Margin="0,5" Fill="#12FFFFFF" />
                        <!-- GPU badge -->
                        <Button Grid.Column="2" Style="{StaticResource ModeBadgeStyle}"
                                BorderBrush="{Binding GpuBadgeBrush}"
                                Tag="3" Click="ModeBadge_Click" ToolTip="GPU Mode">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="7" Height="7"
                                         Fill="{Binding GpuBadgeBrush}"
                                         VerticalAlignment="Center" Margin="0,0,7,0"
                                         IsEnabled="{Binding GpuBadgeIsWarning}"
                                         Style="{StaticResource WarningPulseDotStyle}" />
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource ModeBadgeIconStyle}"
                                           Foreground="{Binding GpuBadgeBrush}" />
                                <TextBlock Text="{Binding GpuBadgeName}"
                                           Style="{StaticResource ModeBadgeValueStyle}"
                                           Foreground="{Binding GpuBadgeBrush}" />
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="3" Margin="0,5" Fill="#12FFFFFF" />
                        <!-- Display badge -->
                        <Button Grid.Column="4" Style="{StaticResource ModeBadgeStyle}"
                                BorderBrush="{Binding DisplayBadgeBrush}"
                                Tag="5" Click="ModeBadge_Click" ToolTip="Display">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="7" Height="7"
                                         Fill="{Binding DisplayBadgeBrush}"
                                         VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Text="&#xE7F8;" Style="{StaticResource ModeBadgeIconStyle}"
                                           Foreground="{Binding DisplayBadgeBrush}" />
                                <TextBlock Text="{Binding DisplayBadgeName}"
                                           Style="{StaticResource ModeBadgeValueStyle}"
                                           Foreground="{Binding DisplayBadgeBrush}" />
                            </StackPanel>
                        </Button>
                        <Rectangle Grid.Column="5" Margin="0,5" Fill="#12FFFFFF" />
                        <!-- Services badge -->
                        <Button Grid.Column="6" Style="{StaticResource ModeBadgeStyle}"
                                BorderBrush="{Binding ServicesBadgeBrush}"
                                Tag="8" Click="ModeBadge_Click" ToolTip="ASUS Services">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="7" Height="7"
                                         Fill="{Binding ServicesBadgeBrush}"
                                         VerticalAlignment="Center" Margin="0,0,7,0"
                                         IsEnabled="{Binding ServicesBadgeIsWarning}"
                                         Style="{StaticResource WarningPulseDotStyle}" />
                                <TextBlock Text="&#xE713;" Style="{StaticResource ModeBadgeIconStyle}"
                                           Foreground="{Binding ServicesBadgeBrush}" />
                                <TextBlock Text="{Binding ServicesBadgeName}"
                                           Style="{StaticResource ModeBadgeValueStyle}"
                                           Foreground="{Binding ServicesBadgeBrush}" />
                            </StackPanel>
                        </Button>
                </Grid>
            </Border>

            <!-- Header accent hairline — reflects overall system health -->
            <Rectangle Grid.Row="2" Grid.ColumnSpan="2"
                       Height="1"
                       Fill="{Binding HeaderAccentBrush}"
                       Opacity="0.6"
                       Margin="14,0,14,0" />
            <Rectangle Grid.Row="2" Grid.ColumnSpan="2"
                       Height="1"
                       Fill="{Binding HeaderAccentBrush}"
                       Opacity="0.2"
                       Margin="0,0,0,0" />

            <!-- Main Content Area -->
            <ScrollViewer Grid.Row="3" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4,4,14,10">
                <Grid x:Name="ContentArea">
                    <panels:MonitorPanel x:Name="PanelMonitor"
                                         DataContext="{Binding Monitor}" />
                    <panels:PerformancePanel x:Name="PanelPerformance"
                                             DataContext="{Binding Performance}"
                                             Visibility="Collapsed" />
                    <panels:FansPowerPanel x:Name="PanelFans"
                                           DataContext="{Binding FansPower}"
                                           Visibility="Collapsed" />
                    <panels:GpuPanel x:Name="PanelGpu"
                                     DataContext="{Binding Gpu}"
                                     Visibility="Collapsed" />
                    <panels:BatteryPanel x:Name="PanelBattery"
                                         DataContext="{Binding Battery}"
                                         Visibility="Collapsed" />
                    <panels:VisualModePanel x:Name="PanelDisplay"
                                            DataContext="{Binding Visual}"
                                            Visibility="Collapsed" />
                    <panels:KeyboardPanel x:Name="PanelKeyboard"
                                          DataContext="{Binding Keyboard}"
                                          Visibility="Collapsed" />
                    <panels:KeyBindingsPanel x:Name="PanelKeyBindings"
                                             DataContext="{Binding KeyBindings}"
                                             Visibility="Collapsed" />
                    <panels:ExtraSettingsPanel x:Name="PanelExtra"
                                               DataContext="{Binding Extra}"
                                               Visibility="Collapsed" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
