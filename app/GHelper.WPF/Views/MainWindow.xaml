<Window x:Class="GHelper.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:panels="clr-namespace:GHelper.WPF.Views.Panels"
        xmlns:local="clr-namespace:GHelper.WPF.Views"
        Title="G-Aether"
        Icon="/Resources/icon.png"
        Width="500"
        Height="620"
        MinWidth="480" MinHeight="400"
        MaxHeight="900"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Foreground="{DynamicResource ForeMainBrush}"
        FontFamily="Segoe UI Variable">

    <!-- Semi-transparent dark background with rounded corners -->
    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12"
            BorderBrush="#18FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Minimal Title Bar (draggable, spans both columns) -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Width="58" TextAlignment="Center" />
                    <TextBlock Text="G-" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForeMainBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Aether" FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Content="&#xE921;"
                            Width="32" Height="28"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    <Button x:Name="CloseButton"
                            Content="&#xE8BB;"
                            Width="32" Height="28"
                            Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}" />
                </StackPanel>
            </Grid>

            <!-- Side Navigation Rail -->
            <Border Grid.Row="1" Grid.Column="0">
                <DockPanel Margin="0,4,0,8" HorizontalAlignment="Stretch">
                    <!-- Settings icon pinned to bottom, with service health dot -->
                    <Grid DockPanel.Dock="Bottom">
                        <RadioButton x:Name="NavExtra" Content="&#xE713;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Settings" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="8" />
                        <!-- Warning dot: visible when ASUS services are running -->
                        <Ellipse Width="7" Height="7"
                                 Fill="#FF6B35"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,6,10,0"
                                 IsHitTestVisible="False">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Extra.AsusServicesCount}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- Update-available dot: visible when a new release is pending -->
                        <Ellipse Width="7" Height="7"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,10,6"
                                 IsHitTestVisible="False"
                                 ToolTip="Update available">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" />
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#60CDFF" BlurRadius="6" ShadowDepth="0" Opacity="0.8" />
                            </Ellipse.Effect>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Extra.UpdateAvailable}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Border DockPanel.Dock="Bottom" Height="1" Margin="6,4,6,4"
                            Background="#18FFFFFF" />

                    <!-- Main nav items -->
                    <StackPanel>
                        <RadioButton x:Name="NavMonitor" Content="&#xE9D9;"
                                     Style="{StaticResource NavIconStyle}"
                                     IsChecked="True" ToolTip="Monitor" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="0" />
                        <RadioButton x:Name="NavPerformance" Content="&#xE945;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Performance" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="1" />
                        <RadioButton x:Name="NavGpu" Content="&#xE7F4;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="GPU Mode" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="3" />
                        <RadioButton x:Name="NavBattery" Content="&#xEA93;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Battery" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="4" />
                        <RadioButton x:Name="NavDisplay" Content="&#xE7F8;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Display" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="5" />
                        <RadioButton x:Name="NavLighting" Content="&#xE781;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Lighting" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="6" />
                        <RadioButton x:Name="NavKeyBindings" Content="&#xE92E;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Key Bindings" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="7" />
                        <RadioButton x:Name="NavProcesses" Content="&#xEB42;"
                                     Style="{StaticResource NavIconStyle}"
                                     ToolTip="Processes" GroupName="Nav"
                                     Checked="Nav_Checked" Tag="10" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Footer bar: Scenes strip + Mode Badge strip, stacked. The Scenes row
                 gives users one-click access to compound presets (Reading, Focus, etc.);
                 the badges row below reports current mode state. Top border is the single
                 visual separator between content and footer. -->
            <Border Grid.Row="2" Grid.ColumnSpan="2"
                    Background="#0BFFFFFF"
                    BorderBrush="#1EFFFFFF"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,11,11"
                    Padding="14,6,14,6"
                    HorizontalAlignment="Stretch">
                <StackPanel>
                    <!-- Scenes strip -->
                    <ItemsControl ItemsSource="{Binding Scenes}" Margin="0,0,0,4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SceneButtonStyle}"
                                        Command="{Binding DataContext.ApplySceneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding Tooltip}"
                                        Margin="3,0">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}" Style="{StaticResource SceneIconStyle}" />
                                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Thin divider between the two rows -->
                    <Border Height="1" Background="#12FFFFFF" Margin="0,0,0,4" />

                    <!-- Mode badges (existing) -->
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Perf badge -->
                    <Button Grid.Column="0" Style="{StaticResource ModeBadgeStyle}"
                            BorderBrush="{Binding ModeStrip.PerfBadgeBrush}"
                            local:ModeBadgeProps.IsActive="{Binding IsChecked, ElementName=NavPerformance}"
                            Tag="1" Click="ModeBadge_Click"
                            ToolTip="{Binding ModeStrip.PerfBadgeName, StringFormat='Performance: {0}. Click to configure.'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE945;" Style="{StaticResource ModeBadgePulseIconStyle}"
                                       Foreground="{Binding ModeStrip.PerfBadgeBrush}"
                                       IsEnabled="{Binding ModeStrip.PerfBadgeIsWarning}" />
                            <TextBlock Text="{Binding ModeStrip.PerfBadgeName}"
                                       Style="{StaticResource ModeBadgeValueStyle}"
                                       Foreground="{Binding ModeStrip.PerfBadgeBrush}" />
                        </StackPanel>
                    </Button>
                    <Rectangle Grid.Column="1" Margin="0,6" Fill="#14FFFFFF" />

                    <!-- GPU badge -->
                    <Button Grid.Column="2" Style="{StaticResource ModeBadgeStyle}"
                            BorderBrush="{Binding ModeStrip.GpuBadgeBrush}"
                            local:ModeBadgeProps.IsActive="{Binding IsChecked, ElementName=NavGpu}"
                            Tag="3" Click="ModeBadge_Click"
                            ToolTip="{Binding ModeStrip.GpuBadgeName, StringFormat='GPU: {0}. Click to configure.'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE950;" Style="{StaticResource ModeBadgePulseIconStyle}"
                                       Foreground="{Binding ModeStrip.GpuBadgeBrush}"
                                       IsEnabled="{Binding ModeStrip.GpuBadgeIsWarning}" />
                            <TextBlock Text="{Binding ModeStrip.GpuBadgeName}"
                                       Style="{StaticResource ModeBadgeValueStyle}"
                                       Foreground="{Binding ModeStrip.GpuBadgeBrush}" />
                        </StackPanel>
                    </Button>
                    <Rectangle Grid.Column="3" Margin="0,6" Fill="#14FFFFFF" />

                    <!-- Display badge -->
                    <Button Grid.Column="4" Style="{StaticResource ModeBadgeStyle}"
                            BorderBrush="{Binding ModeStrip.DisplayBadgeBrush}"
                            local:ModeBadgeProps.IsActive="{Binding IsChecked, ElementName=NavDisplay}"
                            Tag="5" Click="ModeBadge_Click"
                            ToolTip="{Binding ModeStrip.DisplayBadgeName, StringFormat='Display refresh: {0}. Click to configure.'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE7F4;" Style="{StaticResource ModeBadgeIconStyle}"
                                       Foreground="{Binding ModeStrip.DisplayBadgeBrush}" />
                            <TextBlock Text="{Binding ModeStrip.DisplayBadgeName}"
                                       Style="{StaticResource ModeBadgeValueStyle}"
                                       Foreground="{Binding ModeStrip.DisplayBadgeBrush}" />
                        </StackPanel>
                    </Button>
                    <Rectangle Grid.Column="5" Margin="0,6" Fill="#14FFFFFF" />

                    <!-- Services badge -->
                    <Button Grid.Column="6" Style="{StaticResource ModeBadgeStyle}"
                            BorderBrush="{Binding ModeStrip.ServicesBadgeBrush}"
                            local:ModeBadgeProps.IsActive="{Binding IsChecked, ElementName=NavExtra}"
                            Tag="8" Click="ModeBadge_Click"
                            ToolTip="{Binding ModeStrip.ServicesBadgeName, StringFormat='ASUS services: {0}. Click to manage.'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE72E;" Style="{StaticResource ModeBadgePulseIconStyle}"
                                       Foreground="{Binding ModeStrip.ServicesBadgeBrush}"
                                       IsEnabled="{Binding ModeStrip.ServicesBadgeIsWarning}" />
                            <TextBlock Text="{Binding ModeStrip.ServicesBadgeName}"
                                       Style="{StaticResource ModeBadgeValueStyle}"
                                       Foreground="{Binding ModeStrip.ServicesBadgeBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>
                </StackPanel>
            </Border>


            <!-- Main Content Area -->
            <ScrollViewer Grid.Row="1" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4,4,14,4">
                <Grid x:Name="ContentArea">
                    <panels:MonitorPanel x:Name="PanelMonitor"
                                         DataContext="{Binding Monitor}" />
                    <panels:PerformancePanel x:Name="PanelPerformance"
                                             DataContext="{Binding Performance}"
                                             Visibility="Collapsed" />
                    <panels:FansPowerPanel x:Name="PanelFans"
                                           DataContext="{Binding FansPower}"
                                           Visibility="Collapsed" />
                    <panels:GpuPanel x:Name="PanelGpu"
                                     DataContext="{Binding Gpu}"
                                     Visibility="Collapsed" />
                    <panels:BatteryPanel x:Name="PanelBattery"
                                         DataContext="{Binding Battery}"
                                         Visibility="Collapsed" />
                    <panels:VisualModePanel x:Name="PanelDisplay"
                                            DataContext="{Binding Visual}"
                                            Visibility="Collapsed" />
                    <panels:KeyboardPanel x:Name="PanelKeyboard"
                                          DataContext="{Binding Keyboard}"
                                          Visibility="Collapsed" />
                    <panels:KeyBindingsPanel x:Name="PanelKeyBindings"
                                             DataContext="{Binding KeyBindings}"
                                             Visibility="Collapsed" />
                    <panels:ExtraSettingsPanel x:Name="PanelExtra"
                                               DataContext="{Binding Extra}"
                                               Visibility="Collapsed" />
                    <panels:ProcessesPanel x:Name="PanelProcesses"
                                           DataContext="{Binding Processes}"
                                           Visibility="Collapsed" />
                </Grid>
            </ScrollViewer>

            <!-- Atmospheric top-highlight — soft ambient light from above, non-interactive.
                 Last child so it sits above everything visually; IsHitTestVisible=false
                 lets clicks pass through to the controls underneath. -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Grid.Column="0" Grid.ColumnSpan="2"
                    IsHitTestVisible="False"
                    CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#12FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="0.35" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Border>
</Window>
