<Window x:Class="GHelper.WPF.Views.GadgetSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GHelper.WPF.Controls"
        Title="G-Scope Floating Settings"
        Width="500" Height="620"
        MinWidth="480" MinHeight="400"
        MaxHeight="900"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource ForeMainBrush}"
        FontFamily="Segoe UI Variable"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="34" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="G-Scope Floating Settings" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForeMainBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button x:Name="CloseButton"
                        Content="&#xE8BB;"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="32" Height="28"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}" />
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="#2060CDFF" Margin="14,0" />

            <!-- Content -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,14,20,8">
                <StackPanel>

                    <!-- ===================================================== -->
                    <!-- VISIBLE TILES                                         -->
                    <!-- ===================================================== -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Visible Tiles" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,4" />
                            <TextBlock Text="Pick which metrics show on the gadget. The grid reflows automatically."
                                       Style="{StaticResource DimTextStyle}" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Row 0 -->
                                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU Temp" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowCpuTemp, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="dGPU Temp" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowDgpuTemp, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>

                                <!-- Row 1 -->
                                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU Use" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowCpuUse, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="dGPU Use" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowDgpuUse, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>

                                <!-- Row 2 -->
                                <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,12,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="dGPU Power" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowPower, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>
                                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Battery" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowBattery, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>

                                <!-- Row 3 -->
                                <Grid Grid.Row="3" Grid.Column="0" Margin="0,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU Fan" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowCpuFan, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>
                                <Grid Grid.Row="3" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU Fan" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                    <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowGpuFan, Mode=TwoWay}" Width="44" Height="22" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ===================================================== -->
                    <!-- APPEARANCE                                            -->
                    <!-- ===================================================== -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Appearance" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12" />

                            <!-- Mode strip toggle -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Show mode strip" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Show a status strip in the gadget header"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding ShowGadgetModeStrip, Mode=TwoWay}"
                                                       Width="44" Height="22" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Mode strip style — Badges (full PERF/GPU/DISPLAY/SERVICES) vs Compact (Scene · Mode · health dot) -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Strip style" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Badges = full PERF/GPU/DISPLAY/SERVICES (Medium+ only). Compact = Scene · Mode · health dot (every size)."
                                               Style="{StaticResource DimTextStyle}" FontSize="10" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Badges" CommandParameter="badges" Command="{Binding SetGadgetModeStripStyleCommand}" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModeStripBadges}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Compact" CommandParameter="compact" Command="{Binding SetGadgetModeStripStyleCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModeStripCompact}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Hide close button -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Hide close button" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Cleaner look once you've set the toggle hotkey"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding HideGadgetClose, Mode=TwoWay}"
                                                       Width="44" Height="22" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Click-through toggle -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Click-through" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Mouse clicks pass through to whatever is behind the gadget. Disable to move the gadget."
                                               Style="{StaticResource DimTextStyle}" FontSize="10" TextWrapping="Wrap" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding GadgetClickThrough, Mode=TwoWay}"
                                                       Width="44" Height="22" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Hide logo" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Hide the &quot;G-Aether&quot; label in the header"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1"
                                                       IsChecked="{Binding HideGadgetLogo, Mode=TwoWay}"
                                                       Width="44" Height="22" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Transparency -->
                            <StackPanel Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Transparency" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Grid.Column="1" FontSize="10" Foreground="#8090909A" VerticalAlignment="Center"
                                               Text="{Binding GadgetOpacity, StringFormat={}{0:P0}, Mode=OneWay}" />
                                </Grid>
                                <TextBlock Text="Lower = more see-through" Style="{StaticResource DimTextStyle}" FontSize="10" />
                                <Slider Minimum="0.20" Maximum="1.00"
                                        Value="{Binding GadgetOpacity, Mode=TwoWay}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,4,0,0" />
                            </StackPanel>

                            <!-- Size -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Size" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Pick a tile-density preset" Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="X-Small" CommandParameter="xsmall" Command="{Binding SetGadgetSizeCommand}" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGadgetSizeXSmall}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Small" CommandParameter="small" Command="{Binding SetGadgetSizeCommand}" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGadgetSizeSmall}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Medium" CommandParameter="medium" Command="{Binding SetGadgetSizeCommand}" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGadgetSizeMedium}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Large" CommandParameter="large" Command="{Binding SetGadgetSizeCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGadgetSizeLarge}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Accent -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Accent color" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Multi keeps each tile's original color"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button CommandParameter="multi" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand"
                                            ToolTip="Multi (default)">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse>
                                                                    <Ellipse.Fill>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#FF6B6B" Offset="0.0" />
                                                                            <GradientStop Color="#FFB347" Offset="0.2" />
                                                                            <GradientStop Color="#6BCB77" Offset="0.4" />
                                                                            <GradientStop Color="#60CDFF" Offset="0.6" />
                                                                            <GradientStop Color="#A78BFA" Offset="0.8" />
                                                                            <GradientStop Color="#F472B6" Offset="1.0" />
                                                                        </LinearGradientBrush>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentMulti}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="blue" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="Blue">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse Fill="#60CDFF" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentBlue}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="purple" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="Purple">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse Fill="#C084FC" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentPurple}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="green" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="Green">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse Fill="#6BCB77" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentGreen}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="orange" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="Orange">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse Fill="#FFB347" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentOrange}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="red" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="Red">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Ellipse Fill="#FF6B6B" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentRed}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="white" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Margin="0,0,6,0" Cursor="Hand" ToolTip="White">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <!-- Hairline border so the white circle is visible against the dark card. -->
                                                                <Ellipse Fill="#F0F0F2" Stroke="#22FFFFFF" StrokeThickness="1" />
                                                                <Ellipse x:Name="Ring" Stroke="#60CDFF" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentWhite}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button CommandParameter="dark" Command="{Binding SetGadgetAccentCommand}"
                                            Width="22" Height="22" Padding="0" Cursor="Hand" ToolTip="Stealth (near-black)">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <!-- Subtle outline so the dark circle is visible against the dark card. -->
                                                                <Ellipse Fill="#36363B" Stroke="#22FFFFFF" StrokeThickness="1" />
                                                                <Ellipse x:Name="Ring" Stroke="White" StrokeThickness="2" Visibility="Collapsed" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccentDark}" Value="True">
                                                                    <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ===================================================== -->
                    <!-- BEHAVIOR                                              -->
                    <!-- ===================================================== -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Behavior" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Disappear on hover" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Fade out when the mouse passes over so you can click through"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <controls:ToggleSwitch Grid.Column="1" IsChecked="{Binding GadgetHoverFade, Mode=TwoWay}"
                                                       Width="44" Height="22" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Toggle hotkey" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="{Binding GadgetHotkeyText}" Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Set" Command="{Binding SetGadgetHotkeyCommand}"
                                        Style="{StaticResource SecondaryActionButtonStyle}" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearGadgetHotkeyCommand}"
                                        Visibility="{Binding GadgetHotkeyAssigned, Converter={StaticResource BoolToVisibility}}"
                                        Style="{StaticResource SecondaryActionButtonStyle}" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Reset position" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="Snap back to top-right of the primary screen"
                                               Style="{StaticResource DimTextStyle}" FontSize="10" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Reset" Command="{Binding ResetGadgetPositionCommand}"
                                        Style="{StaticResource SecondaryActionButtonStyle}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0" Padding="20,10,20,14">
                <Button Content="Done"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Background="#20FFFFFF" Foreground="White"
                        BorderThickness="0" Padding="20,5"
                        FontSize="11" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
