<Window x:Class="GHelper.WPF.Views.ScopeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GHelper.WPF.Controls"
        Title="G-Scope Settings"
        Width="500" Height="620"
        MinWidth="480" MinHeight="400"
        MaxHeight="900"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource ForeMainBrush}"
        FontFamily="Segoe UI Variable"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="34" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="G-Scope Settings" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForeMainBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button x:Name="CloseButton"
                        Content="&#xE8BB;"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="32" Height="28"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}" />
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="#2060CDFF" Margin="14,0" />

            <!-- Content (filled in Task 12) -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,14,20,8">
                <StackPanel x:Name="ContentStack" />
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0" Padding="20,10,20,14">
                <Button Content="Done"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Background="#20FFFFFF" Foreground="White"
                        BorderThickness="0" Padding="20,5"
                        FontSize="11" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
