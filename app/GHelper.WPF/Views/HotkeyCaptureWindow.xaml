<Window x:Class="GHelper.WPF.Views.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Hotkey"
        Width="380" Height="250"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable">

    <Border Background="#E8141420" CornerRadius="12"
            BorderBrush="#28FFFFFF" BorderThickness="1">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Set Hotkey"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForeMainBrush}" />
                <TextBlock x:Name="ActionLabel"
                           Style="{StaticResource DimTextStyle}"
                           FontSize="11" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#13141B"
                    BorderBrush="#22252E"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,18">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ComboText"
                               Text="Press a combination now"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForeDimBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Use one or more modifiers (Ctrl / Alt / Shift / Win) plus a key. Esc to cancel."
                               Style="{StaticResource DimTextStyle}"
                               FontSize="10"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button x:Name="AcceptButton"
                        Content="Accept"
                        Style="{StaticResource PrimaryApplyButtonStyle}"
                        IsEnabled="False"
                        Click="Accept_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
