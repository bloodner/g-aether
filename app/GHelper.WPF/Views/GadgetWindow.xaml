<Window x:Class="GHelper.WPF.Views.GadgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="G-Aether Gadget"
        Width="260" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Root_MouseLeftButtonDown"
        MouseEnter="Root_MouseEnter"
        MouseLeave="Root_MouseLeave">

    <!-- Match the main G-Aether window chrome via WindowBackgroundBrush so
         the gadget reads as part of the same app. -->
    <Border CornerRadius="12"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="2,0,2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="G-Aether"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" />

                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Width="20" Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource ForeDimBrush}"
                        Cursor="Hand"
                        Click="Hide_Click"
                        ToolTip="Hide gadget" />
            </Grid>

            <!-- 4x2 tile grid -->
            <UniformGrid x:Name="TileGrid" Grid.Row="1" Columns="2" Rows="4" Margin="0">
                <!-- Row 1: CPU Temp / dGPU Temp -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding CpuTempText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#FF6B6B" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="dGPU" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding GpuTempText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#FFB347" />
                    </StackPanel>
                </Border>

                <!-- Row 2: CPU Usage / dGPU Usage -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU Use" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding CpuUseText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#A78BFA" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="dGPU Use" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding GpuUseText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#60CDFF" />
                    </StackPanel>
                </Border>

                <!-- Row 3: Power / Battery -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="Power" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding GpuPowerText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#6BCB77" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="Battery" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding BatteryPercentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#4CC95E" />
                    </StackPanel>
                </Border>

                <!-- Row 4: Fans -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU Fan" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding CpuFanCurrentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#C084FC" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Fan" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding GpuFanCurrentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#F472B6" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
