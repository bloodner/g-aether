<Window x:Class="GHelper.WPF.Views.GadgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="G-Aether Gadget"
        Width="260" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Root_MouseLeftButtonDown"
        MouseEnter="Root_MouseEnter"
        MouseLeave="Root_MouseLeave">

    <!-- Match the main G-Aether window chrome via WindowBackgroundBrush so
         the gadget reads as part of the same app. -->
    <Border CornerRadius="12"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="2,0,2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="G-Aether"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" />

                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Width="20" Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource ForeDimBrush}"
                        Cursor="Hand"
                        Click="Hide_Click"
                        ToolTip="Hide gadget" />
            </Grid>

            <!-- Mode strip — mini of the main window's PERF/GPU/DISPLAY/SERVICES strip.
                 Bound to the same ModeStripViewModel instance the main window uses, so
                 names/colors/warnings always match. Hairline dividers above and below. -->
            <Border x:Name="ModeStripContainer"
                    Grid.Row="1"
                    Margin="0,0,0,8"
                    Padding="2,4,2,4"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Perf badge -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                ToolTip="{Binding ModeStrip.PerfBadgeName, StringFormat='Performance: {0}'}">
                        <TextBlock Text="&#xE945;"
                                   Style="{StaticResource ModeBadgePulseIconStyle}"
                                   Foreground="{Binding ModeStrip.PerfBadgeBrush}"
                                   IsEnabled="{Binding ModeStrip.PerfBadgeIsWarning}" />
                        <TextBlock Text="{Binding ModeStrip.PerfBadgeName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{Binding ModeStrip.PerfBadgeBrush}" />
                    </StackPanel>

                    <!-- GPU badge -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                ToolTip="{Binding ModeStrip.GpuBadgeName, StringFormat='GPU: {0}'}">
                        <TextBlock Text="&#xE950;"
                                   Style="{StaticResource ModeBadgePulseIconStyle}"
                                   Foreground="{Binding ModeStrip.GpuBadgeBrush}"
                                   IsEnabled="{Binding ModeStrip.GpuBadgeIsWarning}" />
                        <TextBlock Text="{Binding ModeStrip.GpuBadgeName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{Binding ModeStrip.GpuBadgeBrush}" />
                    </StackPanel>

                    <!-- Display badge -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                ToolTip="{Binding ModeStrip.DisplayBadgeName, StringFormat='Display: {0}'}">
                        <TextBlock Text="&#xE7F4;"
                                   Style="{StaticResource ModeBadgeIconStyle}"
                                   Foreground="{Binding ModeStrip.DisplayBadgeBrush}" />
                        <TextBlock Text="{Binding ModeStrip.DisplayBadgeName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{Binding ModeStrip.DisplayBadgeBrush}" />
                    </StackPanel>

                    <!-- Services badge -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                ToolTip="{Binding ModeStrip.ServicesBadgeName, StringFormat='Services: {0}'}">
                        <TextBlock Text="&#xE72E;"
                                   Style="{StaticResource ModeBadgePulseIconStyle}"
                                   Foreground="{Binding ModeStrip.ServicesBadgeBrush}"
                                   IsEnabled="{Binding ModeStrip.ServicesBadgeIsWarning}" />
                        <TextBlock Text="{Binding ModeStrip.ServicesBadgeName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{Binding ModeStrip.ServicesBadgeBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Compact strip — Scene · PerfMode · health dot.
                 Same Grid.Row as ModeStripContainer; only one is ever visible.
                 Scales to small gadget widths because it's a single line. -->
            <Border x:Name="CompactStripContainer"
                    Grid.Row="1"
                    Margin="0,0,0,8"
                    Padding="6,5,6,5"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="0,1,0,1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Scene icon (only shown when an active scene is recorded) -->
                        <TextBlock Text="{Binding ModeStrip.ActiveSceneIcon}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,5,0"
                                   Visibility="{Binding ModeStrip.HasActiveScene, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Scene name -->
                        <TextBlock Text="{Binding ModeStrip.ActiveSceneName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Visibility="{Binding ModeStrip.HasActiveScene, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Separator -->
                        <TextBlock Text=" · "
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="#888"
                                   Visibility="{Binding ModeStrip.HasActiveScene, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Performance mode (always shown) -->
                        <TextBlock Text="{Binding ModeStrip.PerfBadgeName}"
                                   Style="{StaticResource ModeBadgeValueStyle}"
                                   Foreground="{Binding ModeStrip.PerfBadgeBrush}" />
                    </StackPanel>
                    <!-- Health dot — green when nominal, amber/red when any badge is in warning state. -->
                    <Ellipse Grid.Column="1" Width="9" Height="9"
                             Fill="{Binding ModeStrip.HealthBrush}"
                             VerticalAlignment="Center" Margin="0,0,2,0">
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.6"
                                              Color="{Binding ModeStrip.HealthBrush.(SolidColorBrush.Color)}" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
            </Border>

            <!-- 4x2 tile grid -->
            <UniformGrid x:Name="TileGrid" Grid.Row="2" Columns="2" Rows="4" Margin="0">
                <!-- Row 1: CPU Temp / dGPU Temp -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.CpuTempText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#FF6B6B" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="dGPU" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.GpuTempText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#FFB347" />
                    </StackPanel>
                </Border>

                <!-- Row 2: CPU Usage / dGPU Usage -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU Use" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.CpuUseText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#A78BFA" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="dGPU Use" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.GpuUseText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#60CDFF" />
                    </StackPanel>
                </Border>

                <!-- Row 3: Power / Battery -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="Power" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.GpuPowerText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#6BCB77" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="Battery" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.BatteryPercentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#4CC95E" />
                    </StackPanel>
                </Border>

                <!-- Row 4: Fans -->
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU Fan" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.CpuFanCurrentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#C084FC" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GadgetTileStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU Fan" Style="{StaticResource GadgetLabelStyle}" />
                        <TextBlock Text="{Binding Monitor.GpuFanCurrentText}" Style="{StaticResource GadgetValueStyle}"
                                   Foreground="#F472B6" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
